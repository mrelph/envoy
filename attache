#!/bin/bash
# Attaché — Your AI Chief of Staff
# Self-contained wrapper - automatically manages dependencies

# Get the actual script location (resolves symlinks)
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
VENV_DIR="$SCRIPT_DIR/venv"
VENV_PYTHON="$VENV_DIR/bin/python3"

# Auto-setup venv if it doesn't exist
if [ ! -f "$VENV_PYTHON" ]; then
    echo "First-time setup: Installing dependencies..."
    python3 -m venv "$VENV_DIR" || exit 1
    "$VENV_DIR/bin/pip" install -q -r "$SCRIPT_DIR/requirements.txt" || exit 1
    echo "Setup complete!"
    echo ""
fi

# Run the CLI
exec "$VENV_PYTHON" "$SCRIPT_DIR/cli.py" "$@"
