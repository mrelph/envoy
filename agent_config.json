{
  "name": "DirectsDigestAgent",
  "description": "Generate AI-powered email digests for your direct reports",
  "version": "1.0.0",
  "capabilities": [
    "email_digest_generation",
    "team_activity_summary",
    "ai_analysis"
  ],
  "tools": [
    {
      "name": "generate_digest",
      "description": "Generate email digest for a manager's direct reports",
      "parameters": {
        "manager_alias": {
          "type": "string",
          "description": "Manager's Amazon alias",
          "required": true
        },
        "days": {
          "type": "integer",
          "description": "Number of days to look back",
          "default": 14
        },
        "include_ai_summary": {
          "type": "boolean",
          "description": "Include AI-powered analysis",
          "default": true
        },
        "email_result": {
          "type": "boolean",
          "description": "Email the digest to the manager",
          "default": false
        }
      }
    }
  ],
  "mcp_servers": {
    "builder-mcp": {
      "command": "builder-mcp",
      "args": []
    },
    "aws-outlook-mcp": {
      "command": "aws-outlook-mcp",
      "args": []
    },
    "teamsnap-mcp": {
      "command": "teamsnap-mcp",
      "args": []
    }
  },
  "runtime": {
    "type": "python",
    "version": "3.9+",
    "entrypoint": "agent_handler.py"
  }
}
