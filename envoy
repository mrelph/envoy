#!/bin/bash
# Envoy — Your AI Chief of Staff
# Self-contained wrapper - automatically manages dependencies

# Get the actual script location (resolves symlinks, portable across macOS and Linux)
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
    LINK_TARGET="$(readlink "$SCRIPT_PATH")"
    if [[ "$LINK_TARGET" == /* ]]; then
        SCRIPT_PATH="$LINK_TARGET"
    else
        SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$LINK_TARGET"
    fi
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
VENV_DIR="$SCRIPT_DIR/venv"
VENV_PYTHON="$VENV_DIR/bin/python3"

# Auto-setup venv if it doesn't exist
if [ ! -f "$VENV_PYTHON" ]; then
    echo "First-time setup: Installing dependencies..."
    if ! python3 -m venv "$VENV_DIR" 2>/dev/null; then
        echo "python3-venv not found — installing it..."
        sudo apt install -y python3-venv || { echo "Failed to install python3-venv"; exit 1; }
        python3 -m venv "$VENV_DIR" || exit 1
    fi
    "$VENV_DIR/bin/pip" install -q -r "$SCRIPT_DIR/requirements.txt" || exit 1
    echo "Setup complete!"
    echo ""
fi

# Ensure Midway auth is fresh (no more than once per hour)
MWINIT_STAMP="$SCRIPT_DIR/.mwinit_last"
if command -v mwinit &>/dev/null; then
    run_mwinit=true
    if [ -f "$MWINIT_STAMP" ]; then
        last=$(cat "$MWINIT_STAMP" 2>/dev/null || echo 0)
        now=$(date +%s)
        if [ $((now - last)) -lt 3600 ]; then
            run_mwinit=false
        fi
    fi
    if $run_mwinit; then
        mwinit -o && date +%s > "$MWINIT_STAMP" || echo "⚠  Midway auth failed — some features may not work"
    fi
fi

# Check for new published releases (at most once every 4 hours)
UPDATE_STAMP="$SCRIPT_DIR/.update_last_check"
CURRENT_VERSION="$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null || echo '0.0.0')"
if [ -d "$SCRIPT_DIR/.git" ]; then
    run_check=true
    if [ -f "$UPDATE_STAMP" ]; then
        last=$(cat "$UPDATE_STAMP" 2>/dev/null || echo 0)
        now=$(date +%s)
        if [ $((now - last)) -lt 14400 ]; then
            run_check=false
        fi
    fi
    if $run_check; then
        date +%s > "$UPDATE_STAMP"
        # Fetch tags and compare against current version (non-blocking)
        (
            git -C "$SCRIPT_DIR" fetch --tags --quiet 2>/dev/null
            LATEST_TAG=$(git -C "$SCRIPT_DIR" tag -l 'v*' --sort=-version:refname 2>/dev/null | head -1)
            if [ -n "$LATEST_TAG" ]; then
                LATEST_VER="${LATEST_TAG#v}"
                if [ "$LATEST_VER" != "$CURRENT_VERSION" ]; then
                    # Compare versions numerically
                    printf '%s\n%s\n' "$CURRENT_VERSION" "$LATEST_VER" | sort -t. -k1,1n -k2,2n -k3,3n | tail -1 | grep -qx "$LATEST_VER"
                    if [ $? -eq 0 ] && [ "$LATEST_VER" != "$CURRENT_VERSION" ]; then
                        echo ""
                        echo "  ⬆  Envoy $LATEST_TAG available (you have v$CURRENT_VERSION). Run 'envoy update' to upgrade."
                        echo ""
                    fi
                fi
            fi
        ) </dev/null >/dev/null 2>&1 &
        disown 2>/dev/null || true
    fi
fi

# Run the CLI
exec "$VENV_PYTHON" "$SCRIPT_DIR/cli.py" "$@"
